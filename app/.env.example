# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WalletConnect (get from https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC endpoints
NEXT_PUBLIC_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
